EMAIL_BRIDGE_PROVIDER=agentmail
AGENTMAIL_API_KEY=am_replace_me
AGENTMAIL_INBOX_ID=your-inbox@agentmail.to
# For EMAIL_BRIDGE_PROVIDER=composio-agentmail, replace the two AgentMail values above with:
# EMAIL_BRIDGE_COMPOSIO_API_KEY=replace_with_scoped_proxy_execute_key
# COMPOSIO_AGENT_MAIL_CONNECTED_ACCOUNT_ID=ca_replace_me
# COMPOSIO_AGENT_MAIL_INBOX_ID=your-inbox@agentmail.to
AGENTMAIL_WEBHOOK_SECRET=whsec_replace_me
# AGENTMAIL_BASE_URL=https://api.agentmail.to/v0
# AGENTMAIL_ALLOW_INSECURE_LOCAL_HTTP=false
EMAIL_BRIDGE_DB_PATH=~/.local/state/hermes-email-bridge/bridge.db
EMAIL_BRIDGE_SEND_REPLIES=false
EMAIL_BRIDGE_DRY_RUN=true
EMAIL_BRIDGE_STORE_RAW=false
EMAIL_BRIDGE_RAW_RETENTION_DAYS=30
EMAIL_BRIDGE_ALLOW_SUBJECT_RESUME=false
EMAIL_BRIDGE_POLL_INTERVAL=30
EMAIL_BRIDGE_LOG_LEVEL=INFO
EMAIL_BRIDGE_WEBHOOK_HOST=127.0.0.1
EMAIL_BRIDGE_WEBHOOK_PORT=8787
EMAIL_BRIDGE_WEBHOOK_QUEUE_SIZE=8
HERMES_COMMAND='/usr/bin/sudo -n -H -u _hermesmail /usr/local/libexec/hermes-email-agent'
HERMES_TIMEOUT=300
